# ====================================================
#  EventoAI - Variables de entorno (EJEMPLO)
#  Autor:  GattiDev
#  Fecha:  01/06/2026
#
#  INSTRUCCIONES:
#  1. Copiar este archivo y renombrarlo a: .env
#     cp .env.example .env
#
#  2. Reemplazar los valores de ejemplo con tus keys reales
#
#  3. NUNCA subas el archivo .env a Git.
#     Ya está incluido en el .gitignore del proyecto.
#
#  El archivo .env.example SÍ se sube a Git, pero sin
#  valores reales, solo como guía para otros desarrolladores.
# ====================================================

# ── Hugging Face (GRATIS) ────────────────────────
# Obtener en: https://huggingface.co/settings/tokens
# Tipo de token: Read
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI / DALL-E 3 (PAGO - opcional) ─────────
# Obtener en: https://platform.openai.com/api-keys
# Requiere cargar créditos (mínimo $5 USD)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Proveedor activo ─────────────────────────────
# Opciones: "huggingface" (por defecto) o "openai"
AI_PROVIDER=huggingface
